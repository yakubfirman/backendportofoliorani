# Copy this file to `.env` and set values before deploying
# Example values for PythonAnywhere or local development

# Secret key for JWT and other security-related features
JWT_SECRET_KEY=change_me_to_a_random_string

# URL of the frontend application allowed by CORS (set in PythonAnywhere Web tab)
FRONTEND_URL=http://localhost:3000

# Optional: set a DATABASE_URL if you want to use an external DB (Postgres/MySQL)
# If omitted, the app uses a local sqlite file `portfolio.db` inside backend/ directory
# Example: postgresql://user:password@host:port/dbname
DATABASE_URL=
