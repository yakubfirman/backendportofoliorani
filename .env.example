# Copy this file to `.env` and set values before deploying.
# Do NOT commit a real `.env` with secrets to the repository.
#
# Generate a strong JWT secret (example):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Default behavior:
# - If `DATABASE_URL` is empty, the app uses a local sqlite file `portfolio.db`.
# - Set `FRONTEND_URL` to your frontend domain (comma-separated list allowed).

# Secret key for JWT and other security-related features (REQUIRED)
JWT_SECRET_KEY=replace_with_a_long_random_string_generated_securely

# URL(s) of the frontend application allowed by CORS (comma-separated)
# e.g. http://localhost:3000, https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional: external database connection string (Postgres/MySQL). Leave blank for sqlite.
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=
